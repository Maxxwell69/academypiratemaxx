# --- lms-backend/.env ---
# MongoDB connection string
URL=mongodb://127.0.0.1:27017/academypiratemaxx
PORT=5000

# --- lms-app/.env.local ---
# Public URL of this Next app (used in Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Express API base URL (must match lms-backend PORT)
BACK_END_URL=http://localhost:5000

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Teacher role: Clerk user id allowed to access teacher routes
NEXT_PUBLIC_TEACHER_ID=

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Mux (video)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# UploadThing (https://uploadthing.com/dashboard)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
